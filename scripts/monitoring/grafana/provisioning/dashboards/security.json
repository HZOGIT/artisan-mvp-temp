      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count{status_code=~\"4..\"}[5m])",
          "legendFormat": "4xx/s",
          "refId": "A"
        },
        {
          "expr": "rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m])",
          "legendFormat": "5xx/s",
          "refId": "B"
