        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(increase(auth_failures_total[1h])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Auth failures par heure (par raison)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
