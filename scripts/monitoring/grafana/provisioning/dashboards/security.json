        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "topk(10, sum(increase(http_request_duration_seconds_count{status_code=\"403\"}[1h])) by (handler))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "title": "403 Forbidden — top 10 endpoints (par heure)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
