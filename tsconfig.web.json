{
  "//": "Gate typecheck strict du frontend React (apps/web/src/**). Lancer : pnpm exec tsc -p tsconfig.web.json --noEmit. `types` ajoute `@fastify/cookie` car tsc suit les imports transitifs AppRouter → source backend qui augmente le module fastify (setCookie/cookies).",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false,
    "tsBuildInfoFile": null,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "target": "ESNext",
    "resolveJsonModule": true,
    "types": ["node", "vite/client", "@fastify/cookie"]
  },
  "include": ["apps/web/src/**/*", "apps/web/src/leaflet.d.ts"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts", "**/*.test.tsx"]
}
