# ==============================================================================
# Production environment — NE JAMAIS committer ce fichier avec des secrets.
#
# Backend Railway : poser les variables dans le dashboard Railway.
# Frontend Cloudflare Pages : les VITE_* sont baked dans le bundle Vite au build.
#   → les poser dans "Environment variables" du projet Pages (dashboard ou CLI) :
#      npx wrangler pages env set VITE_STRIPE_PUBLISHABLE_KEY pk_live_… \
#        --project-name artisan-prod --env production
#   NE PAS utiliser `wrangler pages secret put` pour les VITE_* (runtime Workers
#   uniquement, pas accessible par le bundle Vite).
#
# Règle CLAUDE.md : NE JAMAIS écrire de valeur runtime dans .env.production
#   committé. Seules les constantes publiques non-sensibles (titre, logo) vont
#   dans .env.production. Tout le reste va dans le dashboard du service de déploiement.
# ==============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://app.operioz.com
JWT_SECRET=                          # min 32 chars — Railway dashboard

VITE_APP_TITLE=Operioz               # déjà dans .env.production committé
VITE_APP_LOGO=/logo.png              # déjà dans .env.production committé

# ── Base de données ───────────────────────────────────────────────────────────
POSTGRES_USER=artisan_user
POSTGRES_PASSWORD=                   # Railway dashboard
APP_DB_PASSWORD=                     # Railway dashboard
# DATABASE_URL=postgres://artisan_user:<pass>@<host>:5432/artisan_prod
# APP_DATABASE_URL=postgres://app_tenant:<pass>@<host>:5432/artisan_prod

# ── Stripe ────────────────────────────────────────────────────────────────────
# Utiliser les clés LIVE (sk_live_… / pk_live_…) en production
STRIPE_SECRET_KEY=                   # sk_live_… — Railway dashboard
VITE_STRIPE_PUBLISHABLE_KEY=         # pk_live_… — Cloudflare Pages env vars
STRIPE_WEBHOOK_SECRET=               # whsec_… — Railway dashboard

# Price IDs Stripe production (à retirer quand billing_mode=maison actif)
STRIPE_PRICE_ESSENTIEL_MONTH=
STRIPE_PRICE_ESSENTIEL_YEAR=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_ENTREPRISE_MONTH=
STRIPE_PRICE_ENTREPRISE_YEAR=
STRIPE_PRICE_EXTRA_USER_PRO_MONTH=
STRIPE_PRICE_EXTRA_USER_PRO_YEAR=
STRIPE_PRICE_EXTRA_USER_ENT_MONTH=
STRIPE_PRICE_EXTRA_USER_ENT_YEAR=

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=                      # Railway dashboard
EMAIL_FROM=Operioz <noreply@operioz.com>

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                      # Railway dashboard
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-preview
GEMINI_TEXT_MODEL=gemini-2.0-flash

# ── Logs ──────────────────────────────────────────────────────────────────────
BETTERSTACK_TOKEN=                   # Railway dashboard
