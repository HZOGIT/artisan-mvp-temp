{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false,
    "tsBuildInfoFile": null,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "target": "ESNext",
    "resolveJsonModule": true,
    "types": ["node", "vite/client", "@fastify/cookie"]
  },
  "include": ["apps/admin/src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
