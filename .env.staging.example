# ==============================================================================
# Staging environment — copy to .env.staging and fill in the blanks
# .env.staging est gitignored — ne jamais committer ce fichier avec des secrets.
#
# Backend Railway : ces variables se posent dans le dashboard Railway OU via
#   railway variables set KEY=VALUE
# Frontend Cloudflare Pages : les VITE_* sont résolues au BUILD (Vite les bake
#   dans le bundle JS). Elles se posent dans .env.staging (build local + upload),
#   ou dans "Environment variables" du projet Pages (si build depuis git).
#   NE PAS utiliser `wrangler pages secret put` pour les VITE_* — les secrets
#   wrangler sont pour le runtime Workers, pas pour le bundle Vite.
# ==============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://staging.operioz.com
JWT_SECRET=                          # min 32 chars, générer avec: openssl rand -hex 32

VITE_APP_TITLE=Artisan MVP (staging)
VITE_APP_LOGO=/logo.svg

# ── Base de données PostgreSQL ────────────────────────────────────────────────
# OWNER (provision migrations + grants au boot)
POSTGRES_USER=artisan_user
POSTGRES_PASSWORD=
# DATABASE_URL construite automatiquement depuis POSTGRES_USER/PASSWORD dans docker-compose
# ou posée directement en Railway :
# DATABASE_URL=postgres://artisan_user:<password>@<host>:5432/artisan_mvp

# APP (app_tenant, RLS — pool runtime)
APP_DB_PASSWORD=                     # mot de passe du rôle app_tenant
# APP_DATABASE_URL=postgres://app_tenant:<APP_DB_PASSWORD>@<host>:5432/artisan_mvp

# ── Stripe ────────────────────────────────────────────────────────────────────
# Utiliser les clés TEST (sk_test_… / pk_test_…) en staging
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=         # pk_test_… — baked dans le bundle Vite
STRIPE_WEBHOOK_SECRET=               # whsec_… depuis dashboard.stripe.com → Webhooks

# Price IDs Stripe (abonnements legacy — à retirer quand billing_mode=maison actif)
STRIPE_PRICE_ESSENTIEL_MONTH=
STRIPE_PRICE_ESSENTIEL_YEAR=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_ENTREPRISE_MONTH=
STRIPE_PRICE_ENTREPRISE_YEAR=
STRIPE_PRICE_EXTRA_USER_PRO_MONTH=
STRIPE_PRICE_EXTRA_USER_PRO_YEAR=
STRIPE_PRICE_EXTRA_USER_ENT_MONTH=
STRIPE_PRICE_EXTRA_USER_ENT_YEAR=

# ── Email — resend.com ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=[Staging] Operioz <noreply@operioz.com>

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-preview
GEMINI_TEXT_MODEL=gemini-2.0-flash

# ── Logs — BetterStack Logtail ────────────────────────────────────────────────
# betterstack.com → Logs → Sources → Node.js → "Source token"
BETTERSTACK_TOKEN=

# ── Cloudflare Tunnel (optionnel — si tunnel Cloudflare activé) ───────────────
# terraform output -raw staging_tunnel_token
CLOUDFLARE_TUNNEL_TOKEN_STAGING=

# --- Billing scheduler ---
SCHEDULER_SECRET=<secret-32-bytes-hex>
