{
  // Typecheck legacy (dette OPE-253, non gated — le gate du code neuf = tsconfig.src.json). `server/`
  // a été supprimé (extinction du legacy) : il ne reste que les 4 sidecars PDF/email encore bundlés
  // au runtime par le new-stack (build:newstack → legacy-pdf.mjs / legacy-email.mjs), listés
  // explicitement ci-dessous pour conserver leur couverture de types sans glob `server/**` trompeur.
  "include": [
    "client/src/**/*",
    "packages/contract/**/*"
  ],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./packages/contract/*"]
    }
  }
}
