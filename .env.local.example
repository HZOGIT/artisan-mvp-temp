# ============================================================
# Dev environment — copy to .env.local and fill in the blanks
# DATABASE_URL is injected by docker-compose, do not set here
# ============================================================

# Required
JWT_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxxx

# App
VITE_APP_TITLE=Artisan MVP (dev)
VITE_APP_LOGO=/logo.svg

# Stripe — test keys from dashboard.stripe.com
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (email) — get from resend.com
RESEND_API_KEY=

# AI (optional)
ANTHROPIC_API_KEY=
