# ==============================================================================
# Dev environment — copy to .env.local and fill in the blanks
# DATABASE_URL / APP_DATABASE_URL sont injectées par docker-compose, ne pas mettre ici
# ==============================================================================

# ── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxxx
APP_URL=http://localhost:3000

# ── App (Vite, baked at build) ────────────────────────────────────────────────
VITE_APP_TITLE=Artisan MVP (dev)
VITE_APP_LOGO=/logo.svg

# ── Stripe — test keys from dashboard.stripe.com ──────────────────────────────
# Secret key : sk_test_…
STRIPE_SECRET_KEY=
# Publishable key : pk_test_…  (baked in Vite bundle — NEVER use live key in dev)
VITE_STRIPE_PUBLISHABLE_KEY=
# Webhook secret : whsec_…  (stripe listen --forward-to localhost:3000/api/webhook)
STRIPE_WEBHOOK_SECRET=

# ── Email — resend.com ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=dev@operioz.com

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-preview
GEMINI_TEXT_MODEL=gemini-2.0-flash
# Optionnel — pour la boucle autonome Claude Code
ANTHROPIC_API_KEY=

# ── Logs — BetterStack Logtail (optionnel en dev) ────────────────────────────
BETTERSTACK_TOKEN=

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_TOKEN=
# Feedback (backend runtime) — DB « 🐞 Remontée de bugs »
NOTION_FEEDBACK_DATABASE_ID=
# Use-cases sync (scripts/notion/)
NOTION_USECASES_DATABASE_ID=
NOTION_USECASES_PARENT_PAGE_ID=
